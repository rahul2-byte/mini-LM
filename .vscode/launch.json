{
"version": "0.2.0",
"configurations": [
    {
    "name": "Smoke Training",
    "type": "debugpy",
    "request": "launch",
    "module": "training.cli",
    "args": [
        "--config",
        "${workspaceFolder}/configs/data.yaml",
        "smoke-train",
        "--output-dir",
        "${workspaceFolder}/artifacts/debug-smoke",
        "--sequence-length",
        "32",
        "--max-steps",
        "3"
    ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "UV_CACHE_DIR": "/tmp/mini-llm-uv-cache"
      }
    },
    {
      "name": "All Tests",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "UV_CACHE_DIR": "/tmp/mini-llm-uv-cache"
      }
    },
    {
      "name": "Ingestion Integration Test",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q", "tests/integration/test_ingestion_pipeline.py"],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "UV_CACHE_DIR": "/tmp/mini-llm-uv-cache"
      }
    },
    {
      "name": "Raw Ingestion - Local MinIO",
      "type": "debugpy",
      "request": "launch",
      "module": "data_ingestion.cli",
      "args": [
        "--config",
        "${workspaceFolder}/configs/data.yaml",
        "ingest-local"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "UV_CACHE_DIR": "/tmp/mini-llm-uv-cache"
      }
    },
    {
      "name": "Raw Ingestion - Source",
      "type": "debugpy",
      "request": "launch",
      "module": "data_ingestion.cli",
      "args": [
        "--config",
        "${workspaceFolder}/configs/data.yaml",
        "ingest",
        "--source-id",
        "${input:sourceId}"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "UV_CACHE_DIR": "/tmp/mini-llm-uv-cache"
      }
    },
    {
      "name": "Raw Ingestion - All Sources",
      "type": "debugpy",
      "request": "launch",
      "module": "data_ingestion.cli",
      "args": [
        "--config",
        "${workspaceFolder}/configs/data.yaml",
        "ingest"
      ],
      "cwd": "${workspaceFolder}",
      "python": "${workspaceFolder}/.venv/bin/python",
      "console": "integratedTerminal",
      "justMyCode": false,
      "envFile": "${workspaceFolder}/.env",
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "UV_CACHE_DIR": "/tmp/mini-llm-uv-cache"
      }
    },
    {
      "name": "Current Test File",
      "type": "debugpy",
      "request": "launch",
      "module": "pytest",
      "args": ["-q", "${file}"],
      "cwd": "${workspaceFolder}",
      "console": "integratedTerminal",
      "justMyCode": true,
      "env": {
        "PYTHONPATH": "${workspaceFolder}/src",
        "UV_CACHE_DIR": "/tmp/mini-llm-uv-cache"
      }
    }
  ],
  "inputs": [
    {
      "id": "sourceId",
      "type": "promptString",
      "description": "Configured source ID, for example fineweb_edu"
    }
  ]
}
