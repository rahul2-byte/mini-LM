# Development image override; use a tested immutable tag for production.
MINIO_IMAGE=minio/minio:latest
# These values are read by Docker Compose and never committed in .env.
MINIO_ROOT_USER=miniollmadmin
MINIO_ROOT_PASSWORD=replace-with-a-long-local-password
# Host directory mounted into MinIO's /data volume.
MINIO_DATA_DIR=./.minio/data
